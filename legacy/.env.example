DATABASE_URL="file:./dev.db"
SESSION_SECRET="replace-with-a-long-random-secret"
APP_URL="http://localhost:3000"
PORT="3000"
ELECTRON_START_URL="http://localhost:3000"

# Leave AI_PROVIDER empty to use OpenAI automatically when OPENAI_API_KEY is set.
# Set AI_PROVIDER="mock" for internal fixture summaries and chat.
AI_PROVIDER=""
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Required before saving transcription API keys through the app settings UI.
TRANSCRIPTION_SETTINGS_ENCRYPTION_KEY=""

# User-facing transcription providers:
# TRANSCRIPTION_PROVIDER="openai"
# TRANSCRIPTION_PROVIDER="openai-compatible"
TRANSCRIPTION_PROVIDER=""

# OpenAI transcription.
OPENAI_TRANSCRIPTION_MODEL="gpt-4o-mini-transcribe"
OPENAI_REALTIME_TRANSCRIPTION_MODEL="gpt-realtime-whisper"

# OpenAI-compatible transcription, for local or third-party servers.
OPENAI_COMPATIBLE_TRANSCRIPTION_BASE_URL=""
OPENAI_COMPATIBLE_TRANSCRIPTION_API_KEY=""
OPENAI_COMPATIBLE_TRANSCRIPTION_MODEL="whisper-1"

# Backward-compatible aliases used by legacy scripts.
TRANSCRIPTION_BASE_URL=""
TRANSCRIPTION_API_KEY=""
TRANSCRIPTION_MODEL="whisper-1"

# Internal tests and fixtures only. Do not expose this as a user-selectable provider.
INTERNAL_TRANSCRIPTION_PROVIDER=""

# Experimental/inactive surfaces. Keep mock unless you finish the UI and provider flow.
CALENDAR_PROVIDER="mock"
BILLING_PROVIDER="mock"

# Stripe billing, only used when BILLING_PROVIDER="stripe".
STRIPE_SECRET_KEY=""
STRIPE_PRICE_ID=""

# Google Calendar, only used when CALENDAR_PROVIDER="google".
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""
GOOGLE_CALENDAR_REDIRECT_URI="http://localhost:3000/api/calendar/callback"

# Local seed helper.
SEED_USER_EMAIL=""
SEED_USER_PASSWORD=""
SEED_USER_NAME=""

# Optional real-provider and E2E scripts.
E2E_BASE_URL="http://localhost:3100"
REQUIRE_ALL_REAL_PROVIDERS="false"
