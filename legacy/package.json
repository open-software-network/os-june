{
  "name": "os-notepad",
  "version": "0.1.0",
  "description": "Open-source Mac meeting notes with local capture, transcription, and AI summaries.",
  "license": "MIT",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "native:build": "native/mac-audio-recorder/build.sh",
    "desktop:dev": "pnpm native:build && concurrently -k -n next,electron \"pnpm dev\" \"wait-on http://localhost:3000 && electron .\"",
    "desktop:pack": "pnpm native:build && pnpm build && electron-builder --mac --dir --config electron-builder.json",
    "desktop:build": "pnpm native:build && pnpm build && electron-builder --mac --config electron-builder.json",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "tsx scripts/e2e.ts",
    "e2e:openai": "env AI_PROVIDER=openai E2E_BASE_URL=http://localhost:3200 tsx scripts/e2e.ts",
    "e2e:real-openai-recording": "env E2E_BASE_URL=http://localhost:3300 tsx scripts/e2e-real-openai-recording.ts",
    "providers:real": "tsx scripts/real-providers.ts",
    "providers:real:all": "env REQUIRE_ALL_REAL_PROVIDERS=true tsx scripts/real-providers.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "verify:e2e": "pnpm verify && pnpm e2e",
    "verify:real": "pnpm verify && pnpm e2e:openai && pnpm e2e:real-openai-recording && pnpm providers:real:all"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "electron-is-dev": "^3.0.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.10"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": "1.19.13",
      "hono": "4.12.21",
      "postcss": "8.5.10"
    }
  }
}
