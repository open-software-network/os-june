# June service being monitored.
JUNE_API_URL=https://june-api.opensoftware.co

# OS Accounts OAuth and identity endpoints.
OS_ACCOUNTS_URL=https://accounts.opensoftware.co
OS_ACCOUNTS_API_URL=https://accounts-api.opensoftware.co
OS_ACCOUNTS_CLIENT_ID=

# This monitor's exact public origin. Register the callback below on the
# OS Accounts OAuth client: http://localhost:3010/auth/callback
APP_ORIGIN=http://localhost:3010

# Server-only deployment secret containing comma-separated OS Accounts User ids.
# Unset or empty fails closed. Never commit the real value.
HEALTH_DASHBOARD_AUTHORIZED_USER_IDS=

# Probe timeout in milliseconds. Values are clamped to 500-15000.
HEALTH_PROBE_TIMEOUT_MS=5000
