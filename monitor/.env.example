# Public services being monitored. These defaults point at production.
JUNE_API_URL=https://june-api.opensoftware.co
OS_API_URL=https://api.opensoftware.co
CHAT_API_URL=https://chat-api.opensoftware.co
CHAT_INFERENCE_URL=https://chat-inference.opensoftware.co
CHAT_SYNC_URL=https://chat-sync.opensoftware.co
OS_APP_URL=https://app.opensoftware.co
CHAT_WEB_URL=https://chat.opensoftware.co
HEALTH_DASHBOARD_PROBE_URL=https://os-june-monitor-production.up.railway.app

# OS Accounts OAuth and identity endpoints.
OS_ACCOUNTS_URL=https://accounts.opensoftware.co
OS_ACCOUNTS_API_URL=https://accounts-api.opensoftware.co
OS_ACCOUNTS_CLIENT_ID=

# This dashboard's exact public origin. Register the callback below on the
# OS Accounts OAuth client: http://localhost:3010/auth/callback
APP_ORIGIN=http://localhost:3010

# Server-only deployment secret containing comma-separated OS Accounts User ids.
# Unset or empty fails closed. Never commit the real value.
HEALTH_DASHBOARD_AUTHORIZED_USER_IDS=

# Probe timeout in milliseconds. Values are clamped to 500-15000.
HEALTH_PROBE_TIMEOUT_MS=5000

# Worker-only settings. Store the webhook as a deployment secret and attach
# a persistent volume at /data so alert state survives restarts.
SLACK_HEALTH_WEBHOOK_URL=
# Canonical URL used in Slack alerts and daily summaries.
HEALTH_DASHBOARD_URL=https://health.opensoftware.co
HEALTH_MONITOR_INTERVAL_MS=300000
HEALTH_MONITOR_RETRY_DELAY_MS=15000
HEALTH_MONITOR_STATE_PATH=/data/os-health-state.json
HEALTH_MONITOR_TIME_ZONE=America/New_York
HEALTH_MONITOR_DAILY_HOUR=9
