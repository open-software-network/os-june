# Copy to .env for local development. Do not commit real secrets.

# Required for real transcription and note generation with OpenAI.
# When omitted, the app uses the local mock provider.
OPENAI_API_KEY=

# Required for real transcription and note generation with Venice.
VENICE_API_KEY=

# Optional: force a provider. Valid values: openai, venice, mock.
# Leave empty to use openai when OPENAI_API_KEY is set,
# venice when VENICE_API_KEY is set, otherwise mock.
OS_NOTETAKER_PROVIDER=

# Optional model overrides.
OS_NOTETAKER_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OS_NOTETAKER_GENERATION_MODEL=gpt-5.2

# Optional Venice-specific overrides.
VENICE_API_BASE_URL=https://api.venice.ai/api/v1
VENICE_TRANSCRIPTION_MODEL=nvidia/parakeet-tdt-0.6b-v3
VENICE_GENERATION_MODEL=zai-org-glm-5

# Optional: force transcription language with an ISO-639-1 code.
# Example for Spanish: es. Leave empty for auto-detection.
OS_NOTETAKER_TRANSCRIPTION_LANGUAGE=
