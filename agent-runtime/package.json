{
  "name": "@june/agent-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": "./dist/index.js",
    "./protocol": "./dist/protocol.js"
  },
  "bin": {
    "june-agent-runtime": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild src/main.ts --bundle --platform=node --format=cjs --target=node24 --outfile=dist/sea.cjs --banner:js=\"'use strict';\"",
    "test": "node --disable-warning=ExperimentalWarning --experimental-strip-types --experimental-loader ./test/ts-loader.mjs --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@openai/agents": "0.13.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "esbuild": "0.25.12",
    "postject": "1.0.0-alpha.6",
    "typescript": "5.6.3"
  }
}
