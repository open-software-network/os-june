      "grantable": false
    },
    {
      "id": "notion-update-page",
      "server": "june_notion_actions",
      "provider": "notion",
      "grantable": false
    },
    {
      "id": "create_issue",
      "server": "june_github_actions",
      "provider": "github",
      "grantable": false
    },
    {
      "id": "update_issue",
      "server": "june_github_actions",
      "provider": "github",
      "grantable": false
    },
    {
      "id": "add_comment",
      "server": "june_github_actions",
      "provider": "github",
      "grantable": false
    }
  ],
  "triggers": [
    {
      "id": "email_received",
      "provider": "google",
      "requiredBundles": ["gmail_read"]
    },
    {
      "id": "event_upcoming",
      "provider": "google",
      "requiredBundles": ["calendar_read"]
    }
  ],
  "routine": {
    "sandboxedBaseToolsets": [
      "web",
      "vision",
      "todo",
      "memory",
      "session_search",
      "context_engine"
    ],
    "readToolsets": ["june_gmail", "june_gcal", "june_linear", "june_notion", "june_github"],
    "actionToolsets": [
      "june_gmail_actions",
      "june_gcal_actions",
      "june_linear_actions",
      "june_notion_actions",
      "june_github_actions"
    ],
    "autonomousServerPrefixes": ["june_gmail_auto_", "june_gcal_auto_"]
