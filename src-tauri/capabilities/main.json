{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Main window access to scoped OS Scribe commands.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "deep-link:default",
    "notification:default",
    "dialog:allow-open",
    "process:allow-restart",
    "updater:default"
  ]
}
